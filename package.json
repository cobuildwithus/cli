{
  "name": "@cobuild/cli",
  "version": "0.1.5",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cobuildwithus/cli"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "cli": "./dist/index.js",
    "cobuild": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "prepare": "pnpm build && husky",
    "prepack": "pnpm build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --no-coverage",
    "test:coverage": "vitest run --coverage",
    "docs:drift": "bash scripts/check-agent-docs-drift.sh",
    "docs:gardening": "bash scripts/doc-gardening.sh --fail-on-issues",
    "review:gpt": "cobuild-review-gpt --config scripts/review-gpt.config.sh",
    "wire:status": "pnpm pkg get dependencies.@cobuild/wire",
    "wire:ensure-published": "bash scripts/wire-ensure-published.sh",
    "wire:use-local": "bash scripts/wire-use-local.sh",
    "wire:use-published": "bash scripts/wire-use-published.sh",
    "zip:src": "bash scripts/package-audit-context.sh --zip",
    "verify": "pnpm wire:ensure-published && pnpm typecheck && pnpm test:coverage",
    "changelog:update": "bash scripts/update-changelog.sh",
    "release:notes": "bash scripts/generate-release-notes.sh",
    "release:check": "pnpm install --frozen-lockfile && pnpm verify && pnpm docs:drift && pnpm docs:gardening && pnpm build && bash -n scripts/release.sh scripts/update-changelog.sh scripts/generate-release-notes.sh scripts/committer scripts/repo-tools.config.sh && npm pack --dry-run",
    "release:dry-run": "bash scripts/release.sh patch --dry-run",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "devDependencies": {
    "@cobuild/repo-tools": "^0.1.12",
    "@cobuild/review-gpt": "^0.2.15",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531",
  "dependencies": {
    "@cobuild/wire": "^0.1.5",
    "@farcaster/hub-nodejs": "^0.15.10",
    "@noble/ed25519": "^2.2.3",
    "incur": "0.1.17",
    "viem": "^2.46.3"
  }
}
